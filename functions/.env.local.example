# Meta Marketing API CLI — used by `npm run meta -- <command>`
#
# Copy to functions/.env.local (gitignored) and fill in.
#
# WHY .env.local AND NOT .env:
#   The Firebase CLI reads functions/.env at deploy time and turns every value in it
#   into a runtime environment variable on EVERY deployed Cloud Function. A System User
#   token with ads_management can create campaigns and spend money — it must never be
#   reachable from the Functions runtime. Firebase explicitly never deploys .env.local.
#   Put the CLI credentials here. Nothing else.
#
# Runtime secrets for the deployed functions (META_DATASET_ID, META_CAPI_TOKEN,
# SUPERWALL_WEBHOOK_SECRET) are separate and live in Secret Manager via
# `firebase functions:secrets:set` — not in any file.
#
# META_CAPI_TOKEN IS NOT THE TOKEN BELOW. Generate a dataset-scoped Conversions API token:
#   Events Manager → your dataset → Settings → Generate access token
# That token can only write events. Pasting the System User token from this file into
# META_CAPI_TOKEN would put an ads_management credential — one that can spend money — into
# the Cloud Functions runtime, which is the single thing this whole .env.local / .env split
# exists to prevent. The two must be different tokens.

# --- Auth -------------------------------------------------------------------

# System User token: Business Settings → Users → System Users → Generate Token.
#
# Required:  ads_management (write), ads_read, business_management
# Optional:  pages_show_list, pages_read_engagement — these only let `doctor` READ the
#            Page's name. Creating a creative that posts as the Page does NOT need them;
#            it needs ads_management plus a role on the Page in the same Business.
#
# Two grants that are NOT scopes on the token, and are the usual cause of a baffling 403:
#   · the System User must be ASSIGNED TO THE AD ACCOUNT (Business Settings → Assign Assets)
#   · to read what Meta has recorded for the app (`npm run meta -- events`), the System User
#     must also hold a role ON THE APP (Business Settings → Accounts → Apps → Add People).
#     Without it that call fails with code 3000 — a token can create campaigns for an app
#     it cannot read.
META_ACCESS_TOKEN=

# App secret, from App Dashboard → Settings → Basic. Optional but recommended: when set,
# every request is signed with appsecret_proof, so a stolen token alone is not enough.
META_APP_SECRET=

# --- Assets -----------------------------------------------------------------

# Ad account to operate on, including the act_ prefix.
META_AD_ACCOUNT_ID=act_

# Meta app ID (same value as EXPO_PUBLIC_META_APP_ID in the root .env — public by design).
META_APP_ID=

# Facebook Page ID. REQUIRED for every ad creative: object_story_spec.page_id has no
# default and creative creation fails without it. The System User must have permission
# to publish as this Page. Find it with: npm run meta -- graph me/accounts
META_PAGE_ID=

# Optional. Instagram account to run the ads as. Without it, IG placements render
# using the Facebook Page identity.
META_INSTAGRAM_ACTOR_ID=

# Events Manager dataset linked to the app. NOT the app ID, and NOT a web pixel.
#
# There is no Graph edge from an app to its dataset, so this is a manual lookup:
#   Events Manager → Data Sources → PickleGo (the app) → Settings → Dataset ID
# `npm run meta -- datasets` prints the click-path and what is currently configured.
#
# Without it the Conversions API has no endpoint to POST to, and not one purchase — or
# renewal — ever reaches Meta. The ads half of this CLI works fine without it, which is
# exactly why it can go unnoticed.
#
# The deployed webhook does NOT read this file. Set it in Secret Manager too:
#   firebase functions:secrets:set META_DATASET_ID
META_DATASET_ID=

# App Store URL for promoted_object. Immutable once a campaign is live — get it right.
META_OBJECT_STORE_URL=https://apps.apple.com/app/id6743630735

# --- Guardrails -------------------------------------------------------------
# All budgets in the Meta API are INTEGER MINOR UNITS of THE AD ACCOUNT'S currency —
# and this ad account bills in CAD, not USD. 5000 = CAD $50.00. `doctor` prints the
# real currency and the account minimum; never assume.
#
# These ceilings are what stop a fat-fingered budget from becoming real money. Raise them
# here deliberately, or per-invocation with --max-daily-budget.

# Max daily budget for any single campaign or ad set.
META_MAX_DAILY_BUDGET_CENTS=5000

# Max lifetime budget for any single campaign or ad set.
META_MAX_LIFETIME_BUDGET_CENTS=50000

# Max manual bid.
META_MAX_BID_CENTS=1000

# Max TOTAL daily spend across every ACTIVE ad set in the account. Checked on `resume`.
# A per-entity ceiling alone does not bound spend — ten ad sets at $50 is $500/day.
META_MAX_ACCOUNT_DAILY_CENTS=10000
